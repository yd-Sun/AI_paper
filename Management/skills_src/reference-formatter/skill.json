{
  "id": "reference-formatter",
  "name": "参考文献格式化器",
  "version": "v1.0.0",
  "description": "自动检查和格式化参考文献，支持 GB/T 7714、APA、MLA 等多种引用格式。",
  "min_app_version": "v1.4.0",
  "entry": {
    "module": "entry",
    "class": "ReferenceFormatterSkill"
  },
  "priority": 40,
  "actions": [
    {
      "id": "format_references",
      "label": "格式化文献",
      "description": "将参考文献列表转换为指定格式。",
      "input_schema": {
        "fields": [
          {
            "id": "references",
            "label": "参考文献列表",
            "type": "textarea",
            "required": true,
            "placeholder": "粘贴需要格式化的参考文献"
          },
          {
            "id": "format_style",
            "label": "引用格式",
            "type": "select",
            "required": true,
            "default": "gb7714",
            "options": [
              {
                "label": "GB/T 7714（国标）",
                "value": "gb7714"
              },
              {
                "label": "APA 7th",
                "value": "apa"
              },
              {
                "label": "MLA 9th",
                "value": "mla"
              },
              {
                "label": "Chicago",
                "value": "chicago"
              }
            ]
          },
          {
            "id": "check_duplicates",
            "label": "检查重复",
            "type": "checkbox",
            "default": true,
            "help": "自动检测并标记重复的文献条目"
          }
        ]
      }
    },
    {
      "id": "extract_doi",
      "label": "提取 DOI",
      "description": "从文献列表中提取所有 DOI 编号。",
      "input_schema": {
        "fields": [
          {
            "id": "text",
            "label": "文本内容",
            "type": "textarea",
            "required": true,
            "placeholder": "粘贴包含 DOI 的文本"
          }
        ]
      }
    }
  ],
  "scene_bindings": [
    "paper_write.section",
    "polish.run_task"
  ],
  "global_hook": false
}
